# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here

# OpenAI
OPENAI_API_KEY=your-openai-key-here

# Bot Network Security Keys
BOT_NETWORK_KEY=generate-a-secure-random-key-here
MASTER_BOT_KEY=generate-a-different-secure-key-here

# Calendly Integration (optional)
CALENDLY_WEBHOOK_SECRET=your-calendly-webhook-signing-key-here

# Notifications (optional)
DISCORD_WEBHOOK_URL=your-discord-webhook-url-here

# External Bot APIs (when connecting to other bots)
EXTERNAL_BOT_1_URL=https://other-bot-system.com/api
EXTERNAL_BOT_1_KEY=their-api-key-here
